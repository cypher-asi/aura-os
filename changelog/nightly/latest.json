  "rendered": {
    "title": "Changelog media pipeline reset and Fireworks pricing coverage",
    "intro": "Today's nightly tears out the old screenshot-publishing stack and replaces it with a leaner Browser Use planning pipeline gated by hard quality checks, then closes the day by broadening dev-loop cost accounting to Fireworks-hosted open models.",
    "entries": [
      {
        "batch_id": "entry-1",
        "time_label": "2:34 AM",
        "started_at": "2026-04-24T09:34:25.000Z",
        "ended_at": "2026-04-24T11:04:19.000Z",
        "title": "Changelog media pipeline rebuilt around Browser Use",
        "summary": "The sprawling demo-screenshot pipeline was removed and replaced with a smaller Browser Use planning flow, then hardened through the morning with auth, quality, branding, and split-host fixes.",
        "items": [
          {
            "text": "Retired the legacy changelog media publishing stack, deleting the publish, retry, and history-sync workflows along with thousands of lines of demo screenshot seeding and runner code, and replaced it with an Anthropic-planned Browser Use trial plus a new CaptureLoginView entry point.",
            "commit_shas": [
              "888afbe54b40663a072507842a7e01418d213479"
            ],
            "confidence": "high"
          },
