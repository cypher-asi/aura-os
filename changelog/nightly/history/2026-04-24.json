        "started_at": "2026-04-25T04:01:26.000Z",
        "ended_at": "2026-04-25T04:01:26.000Z",
        "title": "GPT-5.5 available in the model picker",
        "summary": "Late-night change added GPT-5.5 as a selectable model with matching pricing.",
        "items": [
          {
            "text": "Added GPT-5.5 to the model constants, chat input picker, and benchmark pricing tables so it can be selected in chat and metered correctly against usage.",
            "commit_shas": [
              "19b65b784d1a518590252409b798a61da3d19bff"
            ],
            "confidence": "high"
          }
        ]
      }
