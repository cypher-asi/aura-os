        "title": "Observable Windows updater handoff",
        "summary": "The NSIS updater path on Windows now leaves diagnostics behind and brings Aura back up after install.",
        "items": [
          {
            "text": "Windows updates capture a per-version handoff log under the updater stage directory and run a relaunch script that brings Aura back after the NSIS installer exits, ending the silent-quit failure mode.",
            "commit_shas": [
              "b7d61680e560cbca7b1df6f3ec16c783705f7fff"
            ],
            "confidence": "high"
          },
          {
            "text": "The single-instance guard now waits up to 15s when AURA_UPDATE_RELAUNCH is set, so the relaunched process doesn't race the old one for the mutex.",
            "commit_shas": [
              "b7d61680e560cbca7b1df6f3ec16c783705f7fff"
            ],
            "confidence": "high"
          }
        ]
