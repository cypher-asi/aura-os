fastlane_version "2.229.0"
default_platform(:android)

require "base64"
require "shellwords"

def interface_root
  File.expand_path("../..", __dir__)
end

def required_env!(name)
  value = ENV[name]
  UI.user_error!("Missing required environment variable #{name}") if value.to_s.empty?
  value
end

def required_envs!(*names)
  missing = names.select { |name| ENV[name].to_s.empty? }
  return if missing.empty?

  UI.user_error!(
    "Missing required environment variables:\n- #{missing.join("\n- ")}"
  )
end

def package_name
  ENV["ANDROID_PACKAGE_NAME"].to_s.empty? ? "tech.zero.aura" : ENV["ANDROID_PACKAGE_NAME"]
end

def local_android_default_host
  ENV["VITE_ANDROID_DEFAULT_HOST"].to_s.empty? ? "http://10.0.2.2:3100" : ENV["VITE_ANDROID_DEFAULT_HOST"]
end

def connected_android_device_serial
  return ENV["ANDROID_SERIAL"] unless ENV["ANDROID_SERIAL"].to_s.empty?

  devices = `adb devices`.lines.drop(1).map(&:strip)
  devices.each do |line|
    serial, state = line.split(/\s+/, 2)
    return serial if serial && state == "device"
  end

  nil
end

def build_number
  ENV["ANDROID_VERSION_CODE"] || ENV["GITHUB_RUN_NUMBER"] || Time.now.utc.strftime("%Y%m%d%H%M")
end

def version_name
  ENV["ANDROID_VERSION_NAME"].to_s.empty? ? "1.0.#{build_number}" : ENV["ANDROID_VERSION_NAME"]
end

def play_json_key_data
  Base64.decode64(required_env!("ANDROID_PLAY_SERVICE_ACCOUNT_JSON_BASE64"))
end

def ensure_signing!
  required_envs!(
    *%w[
    ANDROID_KEYSTORE_PATH
    ANDROID_KEYSTORE_PASSWORD
    ANDROID_KEY_ALIAS
    ANDROID_KEY_PASSWORD
    ]
  )
end

def build_release_bundle
  sync_android_web_assets
  ensure_signing!

  # Feed versioning and signing through env-backed Gradle config so local and CI
  # release builds follow the same path.
  ENV["ANDROID_VERSION_CODE"] = build_number.to_s
  ENV["ANDROID_VERSION_NAME"] = version_name

  gradle(
    task: "bundle",
    build_type: "Release",
    project_dir: "."
  )

  lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH] || "./app/build/outputs/bundle/release/app-release.aab"
end

def upload_bundle(track:, release_status:)
  aab_path = build_release_bundle
  metadata_present = File.directory?("fastlane/metadata/android")

  upload_to_play_store(
    json_key_data: play_json_key_data,
    package_name: package_name,
    track: track,
    release_status: release_status,
    aab: aab_path,
    skip_upload_metadata: !metadata_present,
    skip_upload_images: true,
    skip_upload_screenshots: true
  )
end

def ensure_play_store_release_requirements!
  ensure_signing!
  required_env!("ANDROID_PLAY_SERVICE_ACCOUNT_JSON_BASE64")
end

private_lane :sync_android_web_assets do
  # Keep local fastlane runs aligned with CI by rebuilding the bundled web app
  # before Gradle packages the native shell.
  root = interface_root.shellescape
  sh("cd #{root} && npm run build")
  sh("cd #{root} && npx cap sync android")
end

platform :android do
  desc "Build a local debug APK that can be installed on an emulator"
  lane :local_debug do
    ENV["VITE_ANDROID_DEFAULT_HOST"] = local_android_default_host
    sync_android_web_assets

    gradle(
      task: "assemble",
      build_type: "Debug",
      project_dir: "."
    )

    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH] || "./app/build/outputs/apk/debug/app-debug.apk"
    serial = connected_android_device_serial

    if serial
      sh("adb -s #{serial.shellescape} install -r #{apk_path.shellescape}")
      sh("adb -s #{serial.shellescape} shell monkey -p #{package_name.shellescape} -c android.intent.category.LAUNCHER 1")
      UI.success("Local debug APK installed and launched on #{serial}")
    else
      UI.important("No connected Android device/emulator found; built APK is ready at #{apk_path}")
    end

    apk_path
  end

  desc "Build and upload an internal testing build to Google Play"
  lane :beta do
    ensure_play_store_release_requirements!
    upload_bundle(
      track: ENV["ANDROID_PLAY_TRACK"].to_s.empty? ? "internal" : ENV["ANDROID_PLAY_TRACK"],
      release_status: "completed"
    )
  end

  desc "Build and upload a release candidate to Google Play"
  lane :release do
    ensure_play_store_release_requirements!
    upload_bundle(
      track: ENV["ANDROID_PLAY_TRACK"].to_s.empty? ? "production" : ENV["ANDROID_PLAY_TRACK"],
      # Default to draft so a release lane run doesn't immediately roll out.
      release_status: ENV["ANDROID_PLAY_RELEASE_STATUS"].to_s.empty? ? "draft" : ENV["ANDROID_PLAY_RELEASE_STATUS"]
    )
  end

  desc "Validate Android Play release configuration without uploading"
  lane :preflight do
    ensure_play_store_release_requirements!
    UI.success("Android Play release configuration looks complete.")
  end
end
