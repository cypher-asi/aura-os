{
  "name": "interface",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm ci --prefix ../vendor/zui --omit=dev",
    "dev": "vite",
    "dev:mobile": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:analyze": "tsc -b && vite build --mode analyze",
    "build:native": "npm run build && npx cap sync",
    "mobile:android:local": "./scripts/run-local-android-fastlane.sh",
    "mobile:ios:local": "./scripts/run-local-ios-fastlane.sh",
    "mobile:local:all": "npm run mobile:android:local && npm run mobile:ios:local",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:sync": "npx cap sync",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:perf": "playwright test --project=perf-desktop-chromium",
    "perf:bundle-budgets": "node ./scripts/check-bundle-budgets.mjs",
    "perf:guardrails": "npm run build && npm run perf:bundle-budgets && npm run test:e2e:perf",
    "test:evals": "playwright test tests/e2e/evals",
    "test:evals:smoke": "playwright test tests/e2e/evals/core-feature-smoke.spec.ts",
    "test:evals:workflow": "playwright test tests/e2e/evals/workflow-e2e.spec.ts",
    "test:evals:benchmark": "playwright test tests/e2e/evals/live-benchmark.spec.ts",
    "test:evals:project-parity": "node ./scripts/run-project-control-plane-parity-eval.mjs",
    "test:mcp-smoke": "node ./scripts/test-dynamic-mcp-sidecar.mjs",
    "test:evals:report": "node ./scripts/summarize-evals.mjs",
    "test:evals:compare": "node ./scripts/compare-evals.mjs",
    "codegen:protocol": "cd .. && cargo test -p aura-protocol --features typescript export_typescript_bindings -- --nocapture && cp crates/aura-protocol/bindings/*.ts interface/src/types/harness-protocol.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@cypher-asi/zui": "file:../vendor/zui",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/extension-bubble-menu": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.475.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
