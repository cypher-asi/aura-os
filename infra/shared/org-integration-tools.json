[
  {
    "name": "list_org_integrations",
    "description": "List saved org integrations that Aura OS can use for shared tools or runtime auth.",
    "promptSignature": "list_org_integrations(provider?)",
    "inputSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Optional provider filter such as github, linear, slack, or notion."
        }
      }
    }
  },
  {
    "name": "github_list_repos",
    "provider": "github",
    "description": "List GitHub repositories accessible through a saved org integration.",
    "promptSignature": "github_list_repos(integration_id?)",
    "inputSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "integration_id": {
          "type": "string",
          "description": "Optional org integration id when multiple GitHub integrations exist."
        }
      }
    }
  },
  {
    "name": "github_create_issue",
