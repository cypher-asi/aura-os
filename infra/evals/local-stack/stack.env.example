# Aura local stack configuration
#
# Copy to:
#   evals/local-stack/stack.env
#
# Then adjust values for your machine.

# Optional stack preset:
# - local
# - hybrid-swarm
# AURA_STACK_PRESET=hybrid-swarm

# Service modes: local | remote | disabled
AURA_STACK_NETWORK_MODE=local
AURA_STACK_STORAGE_MODE=local
AURA_STACK_ORBIT_MODE=local
AURA_STACK_HARNESS_MODE=local

# For local harnesses, choose how the process runs.
# `host` is the default because it can access the imported local workspaces directly.
AURA_STACK_HARNESS_RUNTIME=host

# Optional remote overrides when a service mode is "remote"
# Fill these with your own deployed endpoints when using hybrid-swarm.
# AURA_STACK_REMOTE_NETWORK_URL=https://your-network-host.example.com
# AURA_STACK_REMOTE_STORAGE_URL=https://your-storage-host.example.com
# AURA_STACK_REMOTE_ORBIT_URL=https://your-orbit-host.example.com
# AURA_STACK_REMOTE_HARNESS_URL=https://your-swarm-gateway.example.com

# Shared auth and service-to-service settings
AURA_STACK_AUTH0_DOMAIN=auth.zero.tech
AURA_STACK_NETWORK_AUDIENCE=aura-network
AURA_STACK_STORAGE_AUDIENCE=aura-storage
AURA_STACK_ORBIT_AUDIENCE=orbit
AURA_STACK_AUTH_COOKIE_SECRET=
AURA_STACK_INTERNAL_SERVICE_TOKEN=aura-local-internal-token
# Optional source Aura app used by bootstrap-auth.sh
# AURA_STACK_AUTH_SOURCE_URL=http://127.0.0.1:3100
# AURA_STACK_AUTH_SOURCE_DATA_DIR=/Users/you/Library/Application Support/aura
# AURA_STACK_SOURCE_ACCESS_TOKEN=

# Optional upstream integrations
AURA_STACK_ZOS_API_URL=https://zosapi.zero.tech
# AURA_STACK_ZOS_API_INTERNAL_TOKEN=
# AURA_STACK_ROUTER_URL=https://your-router-host.example.com
# AURA_STACK_BILLING_URL=https://your-billing-host.example.com

# Local ports
AURA_STACK_AURA_OS_PORT=3190
AURA_STACK_FRONTEND_PORT=4317
AURA_STACK_NETWORK_PORT=3401
AURA_STACK_STORAGE_PORT=3402
AURA_STACK_ORBIT_PORT=3403
AURA_STACK_HARNESS_PORT=3404

AURA_STACK_NETWORK_DB_PORT=5441
AURA_STACK_STORAGE_DB_PORT=5442
AURA_STACK_ORBIT_DB_PORT=5443

# Optional repo path overrides
# AURA_STACK_WORKSPACE_ROOT=/Users/you/path/to/zero
# AURA_STACK_NETWORK_DIR=/Users/you/path/to/zero/aura-network
# AURA_STACK_STORAGE_DIR=/Users/you/path/to/zero/aura-storage
# AURA_STACK_ORBIT_DIR=/Users/you/path/to/zero/orbit
# AURA_STACK_HARNESS_DIR=/Users/you/path/to/zero/aura-harness

# CORS and logging
AURA_STACK_CORS_ORIGINS=http://127.0.0.1:4317,http://localhost:4317,http://127.0.0.1:4173,http://localhost:4173
AURA_STACK_NETWORK_LOG_LEVEL=info
AURA_STACK_STORAGE_LOG_LEVEL=info
AURA_STACK_ORBIT_LOG_LEVEL=info
AURA_STACK_HARNESS_LOG_LEVEL=info

# Harness runtime
AURA_STACK_HARNESS_LLM_ROUTING=proxy
AURA_STACK_HARNESS_ENABLE_CMD_TOOLS=true
AURA_STACK_HARNESS_ALLOWED_COMMANDS=npm,node,npx,pnpm,bun,cargo,python,python3,pytest,go,git
# AURA_STACK_AURA_ROUTER_JWT=
# AURA_STACK_ANTHROPIC_API_KEY=
AURA_STACK_ANTHROPIC_MODEL=claude-opus-4-6

# Local benchmark defaults
AURA_STACK_EVAL_BASE_URL=http://127.0.0.1:4317
AURA_STACK_EVAL_BUNDLE_ID=local-stack
# AURA_EVAL_USER_EMAIL=
# AURA_EVAL_USER_PASSWORD=
